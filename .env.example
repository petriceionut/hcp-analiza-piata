# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Personal access token from https://app.supabase.com/account/tokens (needed for run-migrations endpoint)
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token

# One-time admin secret to protect /api/admin/* endpoints
ADMIN_SECRET=change_me_to_something_random

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Email (Resend)
# Use onboarding@resend.dev for testing, or a verified custom domain for production
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=onboarding@resend.dev
